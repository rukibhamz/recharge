# Supabase (API — server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Optional: direct Postgres URL for npm run db:migrate
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase (Web — Vite exposes VITE_* to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production API (required on Vercel — Express does not run on static deploy)
# Leave empty in local dev; Vite proxies /api to localhost:3001
VITE_API_URL=https://your-api-host.example.com

# LLM provider chain (live questions first; banks are fallbacks only)
LLM_PROVIDER_ORDER=gemini,ollama
LLM_PERSONALITY_QUESTIONS=true
LLM_BURNOUT_QUESTIONS=true
LLM_RECOMMENDATIONS=true

# Google Gemini (cloud — tried first)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest
GEMINI_MIN_INTERVAL_MS=4000

# Ollama (local fallback — https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=aiengine-qwen3:latest
OLLAMA_TIMEOUT_MS=120000

# Legacy aliases (still supported)
GEMINI_PERSONALITY_QUESTIONS=true
GEMINI_BURNOUT_QUESTIONS=true
GEMINI_RECOMMENDATIONS=true

# API server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10
POSTHOG_KEY=
