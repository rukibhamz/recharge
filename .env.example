# Supabase (API — server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Supabase (Web — Vite exposes VITE_* to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest
GEMINI_MIN_INTERVAL_MS=4000

# Gemini features (set false to reduce API usage on free tier)
GEMINI_PERSONALITY_QUESTIONS=true
GEMINI_BURNOUT_QUESTIONS=true
GEMINI_RECOMMENDATIONS=true

# API server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10
POSTHOG_KEY=
